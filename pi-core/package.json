{
	"name": "pi-core",
	"type": "module",
	"version": "1.0.0",
	"engines": {
		"node": ">=24"
	},
	"description": "Core foundation for basecamp — primitive registries, session lifecycle, workspace state, and shared contracts.",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"scripts": {
		"check": "tsc && biome check .",
		"typecheck": "tsc",
		"test": "npm run test:platform && npm run test:model-aliases && npm run test:session && npm run test:state && npm run test:workspace",
		"test:platform": "node --experimental-strip-types --test src/platform/tests/*.test.ts",
		"test:model-aliases": "node --experimental-strip-types --test src/model-aliases/tests/*.test.ts",
		"test:session": "node --experimental-strip-types --test src/session/tests/*.test.ts",
		"test:state": "node --experimental-strip-types --test src/state/tests/*.test.ts",
		"test:workspace": "node --experimental-strip-types --test src/workspace/tests/*.test.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix ."
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@earendil-works/pi-agent-core": "^0.78.0",
		"@earendil-works/pi-ai": "^0.78.0",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"@earendil-works/pi-tui": "^0.78.0",
		"@sinclair/typebox": "^0.34.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.8.0"
	}
}
