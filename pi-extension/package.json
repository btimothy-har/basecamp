{
	"name": "basecamp-pi-extension",
	"type": "module",
	"version": "1.0.0",
	"description": "Basecamp extension for pi \u2014 session lifecycle, git protection, project context, workflow, and engineering skills.",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"skills": [
			"./src/workflow/skills",
			"./src/git/skills",
			"./src/engineering/skills"
		],
		"prompts": [
			"./src/engineering/prompts"
		]
	},
	"scripts": {
		"check": "tsc && biome check .",
		"typecheck": "tsc",
		"test:state": "node --experimental-strip-types --test src/state/tests/*.test.ts",
		"test:session": "node --experimental-strip-types --test src/session/tests/*.test.ts",
		"test:model-aliases": "node --experimental-strip-types --test src/model-aliases/tests/*.test.ts src/platform/tests/model-aliases.test.ts src/workflow/tests/model-resolution.test.ts src/session/tests/title-model.test.ts",
		"test:projects": "node --experimental-strip-types --test src/projects/tests/*.test.ts",
		"test:workspace": "node --experimental-strip-types --test src/workspace/tests/*.test.ts",
		"test:safe-git": "node --experimental-strip-types --test src/git/tests/*.test.ts",
		"test:workflow": "node --experimental-strip-types --test src/workflow/tests/*.test.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix ."
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@mariozechner/pi-coding-agent": "^0.67.1",
		"@mariozechner/pi-tui": "^0.67.1",
		"@sinclair/typebox": "^0.34.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.8.0"
	}
}
