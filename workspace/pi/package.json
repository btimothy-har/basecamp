{
	"name": "pi-workspace",
	"type": "module",
	"version": "1.0.0",
	"engines": {
		"node": ">=24"
	},
	"description": "Basecamp workspace config + project context layer — overrides pi-core workspace defaults with basecamp.yaml-aware values.",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		]
	},
	"scripts": {
		"check": "tsc && biome check .",
		"typecheck": "tsc",
		"test": "npm run test:workspace && npm run test:projects",
		"test:workspace": "node --experimental-strip-types --test src/workspace/tests/*.test.ts",
		"test:projects": "node --experimental-strip-types --test src/projects/tests/*.test.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix ."
	},
	"peerDependencies": {
		"pi-core": "*",
		"@earendil-works/pi-coding-agent": "*"
	},
	"devDependencies": {
		"pi-core": "file:../../core/pi",
		"@biomejs/biome": "^2.0.0",
		"@earendil-works/pi-agent-core": "^0.78.0",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"@earendil-works/pi-tui": "^0.78.0",
		"@sinclair/typebox": "^0.34.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.8.0"
	}
}
