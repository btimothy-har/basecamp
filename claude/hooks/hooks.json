{
	"hooks": {
		"SessionStart": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/basecamp-hook\" session-start",
						"timeout": 15
					}
				]
			}
		],
		"SessionEnd": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/basecamp-hook\" session-end",
						"timeout": 10
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/basecamp-hook\" pre-compact",
						"timeout": 10
					}
				]
			}
		],
		"SubagentStop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/basecamp-hook\" subagent-stop",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "\"${CLAUDE_PLUGIN_ROOT}/bin/basecamp-hook\" file-length",
						"timeout": 10
					}
				]
			}
		]
	}
}
