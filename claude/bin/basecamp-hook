#!/bin/sh
# Dispatch a Claude Code lifecycle hook event to basecamp (strictly fail-open).
#
# Prefer an installed `basecamp-hook` console script (basecamp installed as a uv
# tool puts it on PATH); fall back to the module for source/dev environments.
# Guard against invoking this shim recursively if the plugin bin/ is on PATH.
self="$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")"
cli="$(command -v basecamp-hook 2>/dev/null || true)"
if [ -n "$cli" ] && [ "$cli" != "$self" ]; then
  exec "$cli" "$@"
fi
exec python3 -m basecamp.hooks "$@"
