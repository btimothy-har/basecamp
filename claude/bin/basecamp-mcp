#!/bin/sh
# Launch the basecamp MCP context server over stdio.
#
# `uv tool install` exposes `basecamp-mcp` beside `basecamp` in the same bin
# dir, so we resolve it from that install rather than an ambient interpreter.
# Resolution order: on PATH, then beside the `basecamp` entry point, then uv's
# default tool bin (covers a GUI launch whose PATH lacks ~/.local/bin). Guard
# against recursing into this shim if the plugin bin/ is itself on PATH.
self="$(command -v -- "$0" 2>/dev/null || printf '%s' "$0")"

runnable() {
  [ -n "$1" ] && [ -x "$1" ] && [ "$1" != "$self" ]
}

# 1. Directly on PATH (terminal launch: the install's bin dir is on PATH).
cli="$(command -v basecamp-mcp 2>/dev/null || true)"
if runnable "$cli"; then exec "$cli" "$@"; fi

# 2. Beside the `basecamp` entry point (same install, same dir).
base="$(command -v basecamp 2>/dev/null || true)"
if [ -n "$base" ]; then
  sib="$(dirname -- "$base")/basecamp-mcp"
  if runnable "$sib"; then exec "$sib" "$@"; fi
fi

# 3. uv's default tool bin locations (a GUI launch may drop these from PATH).
for dir in "${XDG_BIN_HOME:-}" "$HOME/.local/bin"; do
  [ -n "$dir" ] || continue
  if runnable "$dir/basecamp-mcp"; then exec "$dir/basecamp-mcp" "$@"; fi
done

echo "basecamp-mcp: basecamp is not installed (run: uv run install.py)" >&2
exit 127
