{
	"name": "pi-observer",
	"type": "module",
	"version": "0.8.0",
	"description": "Pi observer extension for session ingestion and semantic recall.",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./extension/src"
		],
		"skills": [
			"./skills"
		]
	},
	"scripts": {
		"check": "tsc && biome check .",
		"typecheck": "tsc",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix ."
	},
	"peerDependencies": {
		"@mariozechner/pi-coding-agent": "*",
		"@sinclair/typebox": "*",
		"@mariozechner/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@mariozechner/pi-coding-agent": "^0.67.1",
		"@mariozechner/pi-tui": "^0.67.1",
		"@sinclair/typebox": "^0.34.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.8.0"
	}
}
