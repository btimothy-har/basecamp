{
	"name": "pi-tasks",
	"type": "module",
	"version": "1.0.0",
	"engines": {
		"node": ">=24"
	},
	"description": "Basecamp task lifecycle + planning — goal tracking, task state machine, /plan command, workflow skills.",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./index.ts"
		],
		"skills": [
			"./src/skills"
		]
	},
	"scripts": {
		"check": "tsc && biome check .",
		"typecheck": "tsc",
		"test": "npm run test:planning && npm run test:agents",
		"test:planning": "node --experimental-strip-types --test src/tests/*.test.ts",
		"test:agents": "node --experimental-strip-types --test src/agents/tests/*.test.ts",
		"lint": "biome check .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix ."
	},
	"peerDependencies": {
		"pi-core": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-tui": "*",
		"@sinclair/typebox": "*"
	},
	"devDependencies": {
		"pi-core": "file:../pi-core",
		"@biomejs/biome": "^2.0.0",
		"@earendil-works/pi-agent-core": "^0.78.0",
		"@earendil-works/pi-ai": "^0.78.0",
		"@earendil-works/pi-coding-agent": "^0.78.0",
		"@earendil-works/pi-tui": "^0.78.0",
		"@sinclair/typebox": "^0.34.0",
		"@types/node": "^22.0.0",
		"typescript": "^5.8.0"
	}
}
