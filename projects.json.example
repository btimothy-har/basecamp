{
  "projects": {
    "myproject": {
      "repo_root": "GitHub/my-project",
      "additional_dirs": [],
      "description": "Full stack project with engineering working style",
      "working_style": "engineering"
    },
    "monorepo": {
      "repo_root": "GitHub/main-repo",
      "additional_dirs": ["GitHub/shared-lib"],
      "description": "repo_root detects the project, additional_dirs add extra roots",
      "working_style": "engineering"
    },
    "data-pipeline": {
      "repo_root": "GitHub/pipeline",
      "additional_dirs": ["GitHub/pipeline-config"],
      "description": "Multi-repo project with custom context",
      "working_style": "engineering",
      "context": "pipeline"
    },
    "minimal": {
      "repo_root": "GitHub/simple-project",
      "additional_dirs": [],
      "description": "Project using the default engineering working style"
    },
    "advisor-project": {
      "repo_root": "GitHub/advisor-project",
      "additional_dirs": [],
      "description": "Project using advisor working style",
      "working_style": "advisor"
    }
  }
}
