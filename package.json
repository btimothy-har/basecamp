{
	"name": "basecamp",
	"private": true,
	"type": "module",
	"version": "0.8.0",
	"engines": {
		"node": ">=24"
	},
	"description": "Basecamp — a project-aware Pi extension suite for AI coding agents.",
	"keywords": [
		"pi-package"
	],
	"pi": {
		"extensions": [
			"./pi/extension.ts"
		],
		"skills": [
			"./pi/tasks/skills",
			"./pi/engineering/skills",
			"./pi/core/swarm/skills"
		],
		"prompts": [
			"./pi/engineering/prompts"
		]
	},
	"imports": {
		"#core/*": "./pi/core/*",
		"#system-prompt/*": "./pi/system-prompt/*",
		"#tasks/*": "./pi/tasks/*",
		"#bash-reviewer/*": "./pi/bash-reviewer/*",
		"#engineering/*": "./pi/engineering/*",
		"#pull-request/*": "./pi/pull-request/*",
		"#browser/*": "./pi/browser/*",
		"#code-review/*": "./pi/code-review/*",
		"#workstreams/*": "./pi/workstreams/*"
	},
	"scripts": {
		"check": "tsc && biome check . && node scripts/check-boundaries.ts && node scripts/check-file-length.ts",
		"typecheck": "tsc",
		"lint": "biome check . && node scripts/check-boundaries.ts && node scripts/check-file-length.ts",
		"lint:fix": "biome check --fix .",
		"format": "biome format --fix .",
		"test": "node --experimental-strip-types --test pi/extension.test.ts \"pi/core/**/*.test.ts\" \"pi/system-prompt/**/*.test.ts\" \"pi/tasks/**/*.test.ts\" \"pi/bash-reviewer/**/*.test.ts\" \"pi/engineering/**/*.test.ts\" \"pi/pull-request/**/*.test.ts\" \"pi/browser/**/*.test.ts\" \"pi/code-review/**/*.test.ts\" \"pi/workstreams/**/*.test.ts\" \"tests/hub/*.test.js\""
	},
	"dependencies": {
		"@playwright/cli": "0.1.17",
		"@sinclair/typebox": "^0.34.0",
		"ws": "^8"
	},
	"peerDependencies": {
		"@earendil-works/pi-ai": "*",
		"@earendil-works/pi-coding-agent": "*",
		"@earendil-works/pi-tui": "*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@earendil-works/pi-agent-core": "^0.80.7",
		"@earendil-works/pi-ai": "^0.80.7",
		"@earendil-works/pi-coding-agent": "^0.80.7",
		"@earendil-works/pi-tui": "^0.80.7",
		"@types/node": "^22.0.0",
		"@types/ws": "^8.18.1",
		"typescript": "^5.8.0"
	}
}
